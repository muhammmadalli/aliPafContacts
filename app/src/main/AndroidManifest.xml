<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Contacts read/write -->
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.WRITE_CONTACTS" />
    <!-- Network: always use mobile data, always assume internet is present -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Sync adapter -->
    <uses-permission android:name="android.permission.AUTHENTICATE_ACCOUNTS" />
    <uses-permission android:name="android.permission.MANAGE_ACCOUNTS" />
    <uses-permission android:name="android.permission.READ_SYNC_SETTINGS" />
    <uses-permission android:name="android.permission.WRITE_SYNC_SETTINGS" />
    <uses-permission android:name="android.permission.READ_SYNC_STATS" />
    <!-- Keep sync running -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />


    <application
        android:name=".AliPafContactsApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/Theme.AliPafContacts"
        android:supportsRtl="true">

        <!-- ──────────────────────────────────────────────
             Main entry point
        ────────────────────────────────────────────── -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Login screen (started by AccountManager when adding an account) -->
        <activity
            android:name=".ui.LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
            </intent-filter>
        </activity>

        <!-- AddressBook selection screen -->
        <activity
            android:name=".ui.AddressBookActivity"
            android:exported="false" />

        <!-- ──────────────────────────────────────────────
             Account Authenticator
             Registers "ali.paf.contacts" as an
             Android account type.
        ────────────────────────────────────────────── -->
        <service
            android:name=".account.AccountAuthenticatorService"
            android:exported="true"
            android:permission="android.permission.ACCOUNT_MANAGER">
            <intent-filter>
                <action android:name="android.accounts.AccountAuthenticator" />
            </intent-filter>
            <meta-data
                android:name="android.accounts.AccountAuthenticator"
                android:resource="@xml/authenticator" />
        </service>

        <!--
             Address-book account type — a *separate* Android account type is
             required (same pattern as DAVx5) because Android only allows one
             address book per account, but CardDAV servers can expose many.
        -->
        <service
            android:name=".account.AddressBookAuthenticatorService"
            android:exported="true"
            android:permission="android.permission.ACCOUNT_MANAGER">
            <intent-filter>
                <action android:name="android.accounts.AccountAuthenticator" />
            </intent-filter>
            <meta-data
                android:name="android.accounts.AccountAuthenticator"
                android:resource="@xml/address_book_authenticator" />
        </service>

        <!-- ──────────────────────────────────────────────
             Contacts Sync Adapter
             Bound to the address-book account type.
        ────────────────────────────────────────────── -->
        <service
            android:name=".sync.ContactsSyncAdapterService"
            android:exported="true"
            android:permission="android.permission.BIND_SYNC_ADAPTER">
            <intent-filter>
                <action android:name="android.content.SyncAdapter" />
            </intent-filter>
            <meta-data
                android:name="android.content.SyncAdapter"
                android:resource="@xml/sync_adapter_contacts" />
        </service>



    </application>
</manifest>
